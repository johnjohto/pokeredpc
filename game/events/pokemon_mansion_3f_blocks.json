     "x": 7,
     "y": 2,
     "block": 95
    }
   ],
   "else": [
    {
     "cmd": "set_block",
     "x": 7,
     "y": 2,
     "block": 14
    }
   ]
  },
  {
   "cmd": "if",
   "cond": "MANSION_SWITCH_ON",
   "then": [
    {
     "cmd": "set_block",
     "x": 7,
     "y": 5,
     "block": 14
    }
   ],
   "else": [
    {
     "cmd": "set_block",
     "x": 7,
     "y": 5,
     "block": 95
    }
   ]
  }
 ]
}
