{
 "$comment": "scripts/OaksLab.asm — the SQUIRTLE ball: 'those are POKé BALLs' before the choose-mon speech (OaksLabThoseArePokeBallsText), the FULLY AUTHORED pick after it (wave C: OaksLabMonChoiceMenu — StarterDex, the pose, the confirm; declining leaves the ball), the untaken leftover once picked (OaksLabLastMonScript). On YES the flag lands just before give_mon (the beat set it between the append and the nickname offer — nothing reads it in that window, and the event is atomic). Then OaksLabRivalChoosesStarterScript: the rival walks to the type-advantage counterpart's ball and takes BULBASAUR.",
 "id": "event:oaks_lab_ball_squirtle",
 "trigger": {
  "kind": "interact",
  "map": "map:OaksLab",
  "object": "SPRITE_POKE_BALL@7,3"
 },
 "commands": [
  {
   "cmd": "if",
   "cond": "not OAK_ASKED_TO_CHOOSE_MON",
   "then": [
    {"cmd": "notice", "text": "Those are POKé\nBALLs. They\ncontain POKéMON!"}
   ],
   "else": [
    {
     "cmd": "if",
     "cond": "not GOT_STARTER",
     "then": [
      {"cmd": "show_dex_entry", "species": "species:squirtle"},
      {"cmd": "pic", "species": "species:squirtle"},
      {
       "cmd": "ask",
       "text": "So! You want the\nwater POKéMON,\nSQUIRTLE?",
       "then": [
        {"cmd": "set_starter", "species": "species:squirtle"},
        {"cmd": "hide_object", "object": "SPRITE_POKE_BALL@7,3"},
        {"cmd": "say", "text": "This POKéMON is\nreally energetic!"},
        {"cmd": "sfx", "key": "get_key_item"},
        {"cmd": "say", "text": "{player} received\na SQUIRTLE!"},
        {"cmd": "clear_pic"},
        {"cmd": "set_flag", "flag": "GOT_STARTER"},
        {"cmd": "give_mon", "species": "species:squirtle", "level": 5, "nickname_offer": true},
        {"cmd": "set_rival_starter", "species": "species:bulbasaur"},
        {"cmd": "walk_object_to", "object": "SPRITE_BLUE@4,3", "to": [8, 4]},
        {"cmd": "face_object", "object": "SPRITE_BLUE@4,3", "dir": "up"},
        {"cmd": "say", "text": "{rival}: I'll take\nthis one, then!"},
        {"cmd": "hide_object", "object": "SPRITE_POKE_BALL@8,3"},
        {"cmd": "say", "text": "{rival} received\na BULBASAUR!"}
       ],
       "else": [
        {"cmd": "clear_pic"}
       ]
      }
     ],
     "else": [
      {"cmd": "notice", "text": "That's PROF.OAK's\nlast POKéMON!"}
     ]
    }
   ]
  }
 ]
}
