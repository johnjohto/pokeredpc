       "key": "go_inside"
      }
     ]
    },
    {
     "cmd": "set_block",
     "x": 12,
     "y": 5,
     "block": 14
    }
   ],
   "else": [
    {
     "cmd": "set_block",
     "x": 12,
     "y": 5,
     "block": 45
    }
   ]
  }
 ]
}
