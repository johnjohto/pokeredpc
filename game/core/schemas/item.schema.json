{
 "$schema": "https://json-schema.org/draft/2020-12/schema",
 "$id": "schema:item",
 "type": "object",
 "required": [
  "id",
  "name"
 ],
 "properties": {
  "id": {
   "type": "string",
   "pattern": "^item:[a-z0-9_.'-]+$"
  },
  "name": {
   "type": "string",
   "minLength": 1
  },
  "price": {
   "type": "integer",
   "minimum": 0
  },
  "tm_move": {
   "type": "string",
   "x-ref": "move"
  },
  "key_item": {
   "type": "boolean"
  },
  "custom": {
   "type": "object"
  }
 },
 "additionalProperties": false
}
