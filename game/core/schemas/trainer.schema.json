{
 "$schema": "https://json-schema.org/draft/2020-12/schema",
 "$id": "schema:trainer",
 "type": "object",
 "required": [
  "id",
  "name",
  "money",
  "parties"
 ],
 "properties": {
  "id": {
   "type": "string",
   "pattern": "^trainer:[a-z0-9_.'-]+$"
  },
  "name": {
   "type": "string",
   "minLength": 1
  },
  "money": {
   "type": "integer",
   "minimum": 0
  },
  "ai": {
   "type": "string"
  },
  "ai_count": {
   "type": "integer",
   "minimum": 0
  },
  "ai_mods": {
   "type": "array",
   "items": {
    "type": "string"
   }
  },
  "pic": {
   "type": "string"
  },
  "parties": {
   "type": "array",
   "minItems": 1,
   "items": {
    "type": "array",
    "minItems": 1,
    "items": {
     "type": "object",
     "required": [
      "species",
      "level"
     ],
     "properties": {
      "species": {
       "type": "string",
       "x-ref": "species"
      },
      "level": {
       "type": "integer",
       "minimum": 1,
       "maximum": 100
      }
     },
     "additionalProperties": false
    }
   }
  },
  "custom": {
   "type": "object"
  }
 },
 "additionalProperties": false
}
