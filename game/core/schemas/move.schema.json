{
 "$schema": "https://json-schema.org/draft/2020-12/schema",
 "$id": "schema:move",
 "type": "object",
 "required": [
  "id",
  "name",
  "type",
  "power",
  "accuracy",
  "pp",
  "effect"
 ],
 "properties": {
  "id": {
   "type": "string",
   "pattern": "^move:[a-z0-9_'-]+$"
  },
  "name": {
   "type": "string",
   "minLength": 1
  },
  "type": {
   "type": "string",
   "x-ref": "type"
  },
  "power": {
   "type": "integer",
   "minimum": 0,
   "maximum": 255
  },
  "accuracy": {
   "type": "integer",
   "minimum": 0,
   "maximum": 100,
   "$comment": "Percent, as v1 stores it (30-100 in Gen 1)."
  },
  "pp": {
   "type": "integer",
   "minimum": 0,
   "maximum": 40
  },
  "effect": {
   "type": "string",
   "minLength": 1
  },
  "sfx": {
   "type": "object",
   "required": [
    "key"
   ],
   "properties": {
    "key": {
     "type": "string"
    },
    "pitch": {
     "type": "integer"
    }
   },
   "additionalProperties": false
  },
  "custom": {
   "type": "object"
  },
  "num": {
   "type": "integer",
   "minimum": 1,
   "$comment": "Canonical Gen-1 table index — iteration order is behavior (Metronome/Mimic pick over the move table order); reconstruction sorts by it."
  }
 },
 "additionalProperties": false
}
