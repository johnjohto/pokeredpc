{
 "$comment": "The v2 project layout (ADR-017/ADR-021): which paths exist, which schema each file matches, and how records declare ids. since_format/until_format make linear project migrations explicit. kind=record: one JSON entity per file; kind=native_map: one TMX map validated by MapDocument; kind=native_asset: a referenced non-JSON authoring document (TSX validation happens through its owning map); kind=table may declare ids; kind=blob is opaque interim presentation data; kind=asset is binary, content-unchecked.",
 "format": 2,
 "layout": [
  {
   "path": "manifest.json",
   "schema": "manifest",
   "kind": "singleton",
   "required": true
  },
  {
   "path": "data/species/*.json",
   "schema": "species",
   "kind": "record",
   "id_prefix": "species"
  },
  {
   "path": "data/moves/*.json",
   "schema": "move",
   "kind": "record",
   "id_prefix": "move"
  },
  {
   "path": "data/items/*.json",
   "schema": "item",
   "kind": "record",
   "id_prefix": "item"
  },
  {
   "path": "data/trainers/*.json",
   "schema": "trainer",
   "kind": "record",
   "id_prefix": "trainer"
  },
  {
   "path": "maps/*.json",
   "schema": "map",
   "kind": "record",
   "id_prefix": "map",
   "id_field": "name",
   "bare_id": true,
   "until_format": 1
  },
  {
   "path": "maps/*.tmx",
   "kind": "native_map",
   "id_prefix": "map",
   "since_format": 2
  },
  {
   "path": "tilesets/*.tsx",
   "kind": "native_asset",
   "since_format": 2
  },
  {
   "path": "data/events/*.json",
   "schema": "event",
   "kind": "record",
   "id_prefix": "event"
  },
  {
   "path": "data/scripts/*.json",
   "schema": "script",
   "kind": "record",
   "id_prefix": "script"
  },
  {
   "path": "data/types.json",
   "schema": "types",
   "kind": "table",
   "declares": {
    "prefix": "type",
    "pointer": "/types"
   }
  },
  {
   "path": "data/encounters.json",
   "schema": "encounters",
   "kind": "table"
  },
  {
   "path": "data/world.json",
   "schema": "world",
   "kind": "table",
   "since_format": 2
  },
  {
   "path": "data/lint_suppressions.json",
   "schema": "lint_suppressions",
   "kind": "table"
  },
  {
   "path": "data/text.json",
   "schema": "text",
   "kind": "table"
  },
  {
   "path": "data/marts.json",
   "schema": "marts",
   "kind": "table"
  },
  {
   "path": "data/prizes.json",
   "schema": "prizes",
   "kind": "table"
  },
  {
   "path": "data/hidden_items.json",
   "schema": "hidden_items",
   "kind": "table"
  },
  {
   "path": "data/trades.json",
   "schema": "trades",
   "kind": "table"
  },
  {
   "path": "data/ruleset.json",
   "schema": "ruleset",
   "kind": "table"
  },
  {
   "path": "data/custom_fields.json",
   "schema": "custom_fields",
   "kind": "table"
  },
  {
   "path": "data/content_types.json",
   "schema": "content_types",
   "kind": "table"
  },
  {
   "path": "presentation/**",
   "schema": "blob",
   "kind": "blob"
  },
  {
   "path": "assets/**",
   "kind": "asset"
  }
 ]
}
